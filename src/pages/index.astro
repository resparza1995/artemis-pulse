---
import QueueDashboard from "../features/pulse/QueueDashboard";
import MainLayout from "../layouts/MainLayout.astro";
import { getBrokerLabel, getServerConfig } from "../lib/config";
import { getLocaleFromRequest, getMessages } from "../i18n";

const { pollIntervalMs } = getServerConfig();
const brokerLabel = getBrokerLabel();
const locale = getLocaleFromRequest({
  cookie: Astro.request.headers.get("cookie"),
  acceptLanguage: Astro.request.headers.get("accept-language"),
});
const m = getMessages(locale);
---

<MainLayout
  pageTitle={m.layout.pages.pulseTitle}
  pageDescription={m.layout.pages.pulseDescription}
  brokerLabel={brokerLabel}
  locale={locale}
>
  <QueueDashboard client:load pollIntervalMs={pollIntervalMs} brokerLabel={brokerLabel} locale={locale} />
</MainLayout>
