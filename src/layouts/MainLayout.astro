---
import { ClientRouter } from "astro:transitions";
import { getMessages, type Locale } from "../i18n";
import { HeaderSettingsButton } from "../features/settings/HeaderSettingsButton";
import { LanguageSwitcher } from "../features/settings/LanguageSwitcher";
import { Toaster } from "../ui/toaster";
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  pageTitle?: string;
  pageDescription?: string;
  brokerLabel?: string;
  locale: Locale;
};

const {
  title = "Artemis Pulse",
  description = "A modern operations console for ActiveMQ Artemis.",
  pageTitle,
  pageDescription,
  brokerLabel,
  locale,
} = Astro.props;
const pathname = Astro.url.pathname;
const m = getMessages(locale);

const navItems = [
  { href: "/", label: m.layout.nav.pulse },
  { href: "/explorer", label: m.layout.nav.explorer },
  { href: "/topology", label: m.layout.nav.topology },
];
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <ClientRouter />
  </head>
  <body>
    <main class="relative h-[100dvh] overflow-hidden">
      <div class="app-shell-backdrop pointer-events-none absolute inset-x-0 top-0 h-64"></div>
      <div class="app-shell-glow pointer-events-none absolute right-0 top-28 h-72 w-72 rounded-full blur-3xl"></div>

      <div class="relative mx-auto flex h-full w-full max-w-[1600px] flex-col px-4 py-4 sm:px-6 sm:py-6 lg:px-8 lg:py-8">
        <header class="app-header-divider mb-3 flex-none py-2 sm:mb-4 sm:py-3">
          <div class="flex flex-wrap items-center justify-between gap-4">
            <div class="flex items-center gap-2">
              <p title={pageDescription ?? ""} class="cursor-help text-[10px] font-semibold uppercase tracking-[0.24em] text-primary/85">
                {m.layout.appName}
              </p>
              <span class="text-[10px] font-semibold text-muted-foreground">|</span>
              <h1 class="font-display text-xl font-semibold tracking-tight text-foreground sm:text-2xl" transition:name="page-title">
                {pageTitle ?? m.layout.nav.explorer}
              </h1>
            </div>

            <div class="flex items-center gap-2">
              {brokerLabel ? (
                <span class="app-panel-muted inline-flex items-center rounded-full px-2 py-1 text-[10px] font-semibold uppercase tracking-[0.16em] text-muted-foreground">
                  {m.layout.broker} {brokerLabel}
                </span>
              ) : null}

              <LanguageSwitcher client:load locale={locale} languageLabel={m.layout.languageLabel} />

              <nav class="app-nav-shell flex items-center gap-1 rounded-full p-1">
                {navItems.map((item) => {
                  const isActive = pathname === item.href;
                  return (
                    <a href={item.href} class:list={["app-nav-item rounded-full px-3 py-1 text-xs font-medium transition duration-200", isActive && "app-nav-item-active"]}>
                      {item.label}
                    </a>
                  );
                })}
              </nav>

              <HeaderSettingsButton client:load locale={locale} />
            </div>
          </div>
        </header>

        <div class="app-page-frame min-h-0 flex-1 overflow-hidden" transition:name="page-content">
          <slot />
        </div>
      </div>
    </main>
    <Toaster client:load />
  </body>
</html>

