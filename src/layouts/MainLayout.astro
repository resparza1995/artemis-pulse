---
import "../styles/global.css";

type Props = {
  title?: string;
  description?: string;
  pageTitle?: string;
  pageDescription?: string;
  compactHeader?: boolean;
  brokerLabel?: string;
};

const {
  title = "Artemis Pulse",
  description = "A modern operations console for ActiveMQ Artemis.",
  pageTitle,
  pageDescription,
  compactHeader = false,
  brokerLabel,
} = Astro.props;
const pathname = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Pulse" },
  { href: "/explorer", label: "Explorer" },
];
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <main class="relative min-h-screen">
      <div class="app-shell-backdrop pointer-events-none absolute inset-x-0 top-0 h-64"></div>
      <div class="app-shell-glow pointer-events-none absolute right-0 top-28 h-72 w-72 rounded-full blur-3xl"></div>

      <div class="relative mx-auto flex min-h-screen w-full max-w-[1600px] flex-col px-4 py-6 sm:px-6 sm:py-8 lg:px-8 lg:py-10">
        <header class="app-header-divider mb-6 pb-5 sm:mb-8">
          <div class="flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
            <div class="space-y-3">
              <div class="flex flex-wrap items-center gap-3">
                <p class="text-[11px] font-semibold uppercase tracking-[0.24em] text-primary/85">
                  Artemis Pulse
                </p>
                {brokerLabel ? (
                  <span class="app-panel-muted inline-flex items-center rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-muted-foreground">
                    broker {brokerLabel}
                  </span>
                ) : null}
              </div>

              {compactHeader ? (
                <div class="space-y-1.5">
                  <h1 class="font-display text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
                    {pageTitle ?? "Artemis Pulse"}
                  </h1>
                  {pageDescription ? (
                    <p class="max-w-3xl text-sm leading-6 text-muted-foreground">
                      {pageDescription}
                    </p>
                  ) : null}
                </div>
              ) : (
                <div class="grid gap-4 lg:grid-cols-[minmax(0,1fr)_minmax(280px,520px)] lg:items-end">
                  <div class="space-y-2.5">
                    <h1 class="font-display text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
                      {pageTitle ?? "A modern operations console for ActiveMQ Artemis."}
                    </h1>
                    {pageDescription ? (
                      <p class="max-w-3xl text-sm leading-6 text-muted-foreground">
                        {pageDescription}
                      </p>
                    ) : null}
                  </div>
                  <p class="text-sm leading-6 text-muted-foreground lg:justify-self-end">
                    Operacion clara del broker, lectura rapida de colas y acceso directo a las vistas mas utiles.
                  </p>
                </div>
              )}
            </div>

            <nav class="app-nav-shell flex items-center gap-2 rounded-full p-1">
              {navItems.map((item) => {
                const isActive = pathname === item.href;

                return (
                  <a
                    href={item.href}
                    class:list={[
                      "app-nav-item rounded-full px-4 py-2 text-sm font-medium transition duration-200",
                      isActive && "app-nav-item-active",
                    ]}
                  >
                    {item.label}
                  </a>
                );
              })}
            </nav>
          </div>
        </header>

        <slot />
      </div>
    </main>
  </body>
</html>
